---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArtworkGrid from '../components/ArtworkGrid.astro';
import { getCollection } from 'astro:content';

const allArtworks = await getCollection('artworks');
const abstract = allArtworks.filter(a => a.data.category === 'abstract');
---

<BaseLayout
  title="Abstract Works"
  description="Abstract paintings by Ian Brennan. Responses to elements and nature through intriguing surface texture and balanced composition."
>
  <section class="gallery-page container">
    <div class="gallery-page__header">
      <h1>Abstract Works</h1>
      <p class="gallery-page__count">{abstract.length} works</p>
    </div>
    <ArtworkGrid artworks={abstract} />
  </section>
</BaseLayout>

<style>
  .gallery-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  .gallery-page__header {
    margin-bottom: var(--space-8);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .gallery-page__header h1 {
    font-size: var(--text-2xl);
  }

  .gallery-page__count {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }
</style>
