---
import { Image } from 'astro:assets';

interface Props {
  slug: string;
  title: string;
  year: string;
  medium: string;
  image: ImageMetadata;
  eager?: boolean;
}

const { slug, title, year, medium, image, eager = false } = Astro.props;
---

<a href={`/work/${slug}`} class="artwork-card" data-astro-prefetch data-reveal>
  <div class="artwork-card__image-wrap">
    <Image
      src={image}
      alt={title}
      widths={[400, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 50vw"
      loading={eager ? 'eager' : 'lazy'}
      format="webp"
      quality={82}
      transition:name={`art-${slug}`}
    />
  </div>
  <div class="artwork-card__info">
    <h3 class="artwork-card__title">{title}</h3>
    <p class="artwork-card__meta">{year} &middot; {medium}</p>
  </div>
</a>

<style>
  .artwork-card {
    display: block;
    break-inside: avoid;
    margin-bottom: var(--space-6);
    transition: transform var(--duration) var(--ease-out);
  }

  .artwork-card:hover {
    transform: translateY(-3px);
  }

  .artwork-card__image-wrap {
    overflow: hidden;
    background-color: var(--color-bg-alt);
    transition: box-shadow var(--duration-slow) var(--ease-out);
  }

  .artwork-card:hover .artwork-card__image-wrap {
    box-shadow: 0 18px 40px -16px rgba(0, 0, 0, 0.22);
  }

  .artwork-card__image-wrap img {
    width: 100%;
    height: auto;
    transition: transform var(--duration-slow) var(--ease-out);
    will-change: transform;
  }

  .artwork-card:hover .artwork-card__image-wrap img {
    transform: scale(1.025);
  }

  .artwork-card__info {
    padding-top: var(--space-2);
  }

  .artwork-card__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1.3;
  }

  .artwork-card__meta {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }
</style>
