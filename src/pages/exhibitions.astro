---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Exhibitions"
  description="Exhibition history, awards, and press for Ian Brennan. London Art Biennale 2021 Winner."
>
  <section class="container"><div class="exhibitions">
    <h1>Exhibitions &amp; CV</h1>

    <div class="cv-section">
      <h2>Solo Exhibitions</h2>
      <ul class="cv-list">
        <li><span class="cv-year">2023</span> Decorex, Olympia Building, London</li>
        <li><span class="cv-year">2019</span> Smock Alley Theatre, Dublin, Ireland</li>
        <li><span class="cv-year">2019</span> Tinahely Art Centre, Wicklow, Ireland</li>
        <li><span class="cv-year">2019</span> St. Luke's, Cork (Culture Night), Ireland</li>
      </ul>
    </div>

    <div class="cv-section">
      <h2>Group Exhibitions</h2>
      <ul class="cv-list">
        <li><span class="cv-year">2023</span> Flux Exhibition, Chelsea, London</li>
        <li><span class="cv-year">2023</span> Art Number 23, Cromwell Place, London</li>
        <li><span class="cv-year">2023</span> Contemporary Masters, NakedEye Gallery, Devon</li>
        <li><span class="cv-year">2021</span> London Art Biennale, Chelsea Old Town Hall, London</li>
        <li><span class="cv-year">2019</span> Kinsale Arts Festival, Ireland</li>
      </ul>
    </div>

    <div class="cv-section">
      <h2>Awards</h2>
      <ul class="cv-list">
        <li><span class="cv-year">2021</span> London Art Biennale &mdash; Award Winner</li>
      </ul>
    </div>

    <div class="cv-section">
      <h2>Education</h2>
      <ul class="cv-list">
        <li><span class="cv-year">2019&ndash;</span> Self-taught artist</li>
        <li><span class="cv-year"></span> Background in Counselling &amp; Psychotherapy</li>
      </ul>
    </div>
  </div></section>
</BaseLayout>

<style>
  .exhibitions {
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
    max-width: 800px;
  }

  .exhibitions h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-12);
  }

  .cv-section {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .cv-section:last-child {
    border-bottom: none;
  }

  .cv-section h2 {
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .cv-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cv-list li {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.5;
    display: flex;
    gap: var(--space-4);
  }

  .cv-year {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    min-width: 60px;
    flex-shrink: 0;
    padding-top: 0.2em;
  }
</style>
