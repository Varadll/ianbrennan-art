---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allArtworks = await getCollection('artworks');
const figurative = allArtworks.filter(a => a.data.category === 'figurative').sort((a, b) => a.data.order - b.data.order);
const abstract = allArtworks.filter(a => a.data.category === 'abstract').sort((a, b) => a.data.order - b.data.order);

// Hero rotation: 3 strongest abstracts
const heroSlugs = ['abstract/accidental-waking', 'abstract/the-red-sea', 'abstract/opening'];
const heroArtworks = heroSlugs
  .map((id) => abstract.find((a) => a.id === id))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));

const featuredFigurative = figurative[1] || figurative[0];
const featuredAbstract = abstract.find((a) => a.id === 'abstract/accidental-waking') || abstract[0];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero" aria-label="Featured artwork">
    <div class="hero__stage">
      {heroArtworks.map((art, i) => {
        const perSlide = 8; // seconds visible
        const fadeIn = 1.5;
        const total = heroArtworks.length * perSlide;
        // Negative delay for first slide so it starts already visible (mid-fade-in).
        const delay = i === 0 ? -fadeIn : i * perSlide - fadeIn;
        return (
          <div
            class="hero__slide"
            style={`animation-duration:${total}s;animation-delay:${delay}s;`}
          >
            <Image
              src={art.data.image}
              alt={art.data.title}
              widths={[1200, 1800, 2400]}
              sizes="100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              format="webp"
              quality={85}
              {...(i === 0 ? { fetchpriority: 'high' } : {})}
            />
          </div>
        );
      })}
      <div class="hero__overlay" aria-hidden="true"></div>
    </div>

    <a href="#intro" class="hero__scroll" aria-label="Scroll to content">
      <span class="hero__scroll-label">Scroll</span>
      <span class="hero__scroll-line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- Intro -->
  <section id="intro" class="intro container" data-reveal>
    <p class="intro__text">
      Figurative and abstract paintings by Ian Brennan.<br />
      <span class="intro__accent">London Art Biennale 2021 Winner</span>
    </p>
  </section>

  <!-- Categories -->
  <section class="categories container">
    <a href="/figurative" class="category-block" data-astro-prefetch data-reveal>
      <div class="category-block__image-wrap">
        <Image
          src={featuredFigurative.data.image}
          alt={featuredFigurative.data.title}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
          format="webp"
          quality={82}
        />
      </div>
      <div class="category-block__info">
        <h2>Figurative</h2>
        <!-- count removed per client -->
        <span class="category-block__link">View Collection &rarr;</span>
      </div>
    </a>

    <a href="/abstract" class="category-block" data-astro-prefetch data-reveal>
      <div class="category-block__image-wrap">
        <Image
          src={featuredAbstract.data.image}
          alt={featuredAbstract.data.title}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
          format="webp"
          quality={82}
        />
      </div>
      <div class="category-block__info">
        <h2>Abstract</h2>
        <!-- count removed per client -->
        <span class="category-block__link">View Collection &rarr;</span>
      </div>
    </a>
  </section>
</BaseLayout>

<style>
  /* ============ Hero ============ */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 560px;
    overflow: hidden;
    background-color: #111;
    /* global.css rule: margin-top: calc(-1 * var(--header-height)) pulls hero
       up behind the fixed transparent header */
  }

  .hero__stage {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation-name: heroCycle;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    animation-fill-mode: both;
  }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.05);
    animation: heroDrift 24s ease-in-out infinite alternate;
  }

  /* 3 slides × 8s = 24s cycle. Visible window = 33.3%, fade ≈ 6.25%. */
  @keyframes heroCycle {
    0%    { opacity: 0; }
    6.25% { opacity: 1; }
    33.3% { opacity: 1; }
    39.6% { opacity: 0; }
    100%  { opacity: 0; }
  }

  @keyframes heroDrift {
    from { transform: scale(1.04) translate3d(0, 0, 0); }
    to   { transform: scale(1.08) translate3d(0, -1.5%, 0); }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.15) 35%,
      rgba(0, 0, 0, 0.15) 65%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }

  .hero__scroll {
    position: absolute;
    z-index: 2;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    animation: heroFadeIn 1.4s 0.6s var(--ease-out) both;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.9), rgba(255,255,255,0));
    animation: scrollPulse 2.4s ease-in-out infinite;
    transform-origin: top;
  }

  @keyframes scrollPulse {
    0%   { transform: scaleY(0.4); opacity: 0.4; }
    50%  { transform: scaleY(1);   opacity: 1; }
    100% { transform: scaleY(0.4); opacity: 0.4; }
  }

  /* ============ Intro ============ */
  .intro {
    text-align: center;
    padding: var(--space-12) 0 var(--space-8);
  }

  .intro__text {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  .intro__accent {
    color: var(--color-text);
    font-style: italic;
  }

  /* ============ Categories ============ */
  .categories {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .categories {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }

  .category-block {
    display: block;
  }

  .category-block__image-wrap {
    overflow: hidden;
    background-color: var(--color-bg-alt);
    aspect-ratio: 4 / 5;
  }

  .category-block__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out),
                opacity var(--duration) var(--ease);
    will-change: transform;
  }

  .category-block:hover .category-block__image-wrap img {
    transform: scale(1.03);
  }

  .category-block__info {
    padding-top: var(--space-3);
  }

  .category-block__info h2 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
  }

  .category-block__count {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .category-block__link {
    display: inline-block;
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-secondary);
    transition: color var(--duration) var(--ease);
  }

  .category-block:hover .category-block__link {
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide,
    .hero__slide img,
    .hero__scroll-line,
    .hero__scroll {
      animation: none !important;
    }
    .hero__slide:first-child { opacity: 1; }
  }
</style>
