---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allArtworks = await getCollection('artworks');
const figurative = allArtworks.filter(a => a.data.category === 'figurative').sort((a, b) => a.data.order - b.data.order);
const abstract = allArtworks.filter(a => a.data.category === 'abstract').sort((a, b) => a.data.order - b.data.order);

const heroArtwork = figurative[0];
const featuredFigurative = figurative[1] || figurative[0];
const featuredAbstract = abstract[0];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__image-wrap">
      <Image
        src={heroArtwork.data.image}
        alt={heroArtwork.data.title}
        widths={[800, 1200, 1800]}
        sizes="100vw"
        loading="eager"
        format="webp"
        quality={85}
      />
    </div>
    <div class="hero__caption container">
      <p class="hero__title">{heroArtwork.data.title}</p>
      <p class="hero__meta">{heroArtwork.data.year}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro container">
    <p class="intro__text">
      Figurative and abstract paintings by Ian Brennan.<br />
      <span class="intro__accent">London Art Biennale 2021 Winner</span>
    </p>
  </section>

  <!-- Categories -->
  <section class="categories container">
    <a href="/figurative" class="category-block" data-astro-prefetch>
      <div class="category-block__image-wrap">
        <Image
          src={featuredFigurative.data.image}
          alt={featuredFigurative.data.title}
          widths={[400, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
          format="webp"
          quality={80}
        />
      </div>
      <div class="category-block__info">
        <h2>Figurative</h2>
        <p class="category-block__count">{figurative.length} works</p>
        <span class="category-block__link">View Collection &rarr;</span>
      </div>
    </a>

    <a href="/abstract" class="category-block" data-astro-prefetch>
      <div class="category-block__image-wrap">
        <Image
          src={featuredAbstract.data.image}
          alt={featuredAbstract.data.title}
          widths={[400, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
          format="webp"
          quality={80}
        />
      </div>
      <div class="category-block__info">
        <h2>Abstract</h2>
        <p class="category-block__count">{abstract.length} works</p>
        <span class="category-block__link">View Collection &rarr;</span>
      </div>
    </a>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-8) 0 var(--space-4);
  }

  .hero__image-wrap {
    width: 100%;
    max-width: 1000px;
    padding: 0 var(--space-4);
  }

  .hero__image-wrap img {
    width: 100%;
    height: auto;
  }

  .hero__caption {
    text-align: center;
    padding-top: var(--space-3);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  .hero__meta {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  /* Intro */
  .intro {
    text-align: center;
    padding: var(--space-12) 0;
  }

  .intro__text {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .intro__accent {
    color: var(--color-text);
    font-style: italic;
  }

  /* Categories */
  .categories {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .categories {
      grid-template-columns: 1fr 1fr;
    }
  }

  .category-block {
    display: block;
  }

  .category-block__image-wrap {
    overflow: hidden;
    background-color: var(--color-bg-alt);
    aspect-ratio: 1;
  }

  .category-block__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--duration) var(--ease);
  }

  .category-block:hover .category-block__image-wrap img {
    opacity: 0.92;
  }

  .category-block__info {
    padding-top: var(--space-3);
  }

  .category-block__info h2 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
  }

  .category-block__count {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .category-block__link {
    display: inline-block;
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    transition: color var(--duration) var(--ease);
  }

  .category-block:hover .category-block__link {
    color: var(--color-text);
  }
</style>
