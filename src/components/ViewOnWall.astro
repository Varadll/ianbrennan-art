---
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  widthCm: number;
  heightCm: number;
  title: string;
  dimensions: string;
}

const { src, alt, widthCm, heightCm, title, dimensions } = Astro.props;

// Reference scale baked into wall-scene.svg:
//   - viewBox is 1600 × 1200, sofa is exactly 800 px wide = 200 cm  →  4 px / cm
//   - the floor line is at y = 900 (so 900 px = ~225 cm of wall above floor)
//   - we hang the painting so its centre sits at y = 460 in scene coords
//     (≈ 110 cm above the floor — slightly above sofa back, looks balanced for most works)
const SCENE_W = 1600;
const SCENE_H = 1200;
const PX_PER_CM = 4;
const HANG_CENTRE_Y = 460; // in scene coords
---

<div class="vow">
  <button type="button" class="vow__open" data-vow-open aria-haspopup="dialog">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <rect x="3" y="3" width="18" height="14" rx="1"/>
      <path d="M3 17l4-4 4 3 6-6 4 4"/>
    </svg>
    View on the Wall
  </button>

  <dialog
    class="vow__dialog"
    data-vow-dialog
    data-scene-w={SCENE_W}
    data-scene-h={SCENE_H}
    data-px-per-cm={PX_PER_CM}
    data-hang-y={HANG_CENTRE_Y}
    data-w-cm={widthCm}
    data-h-cm={heightCm}
    aria-labelledby="vow-title"
  >
    <button type="button" class="vow__close" data-vow-close aria-label="Close">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M5 5l14 14M19 5L5 19"/>
      </svg>
    </button>

    <div class="vow__scene" data-vow-scene>
      <img class="vow__bg" src="/room/wall-scene.svg" alt="" aria-hidden="true" />
      <div class="vow__art" data-vow-art>
        <Image
          src={src}
          alt={alt}
          widths={[400, 800, 1200]}
          sizes="60vw"
          loading="lazy"
          format="webp"
          quality={85}
        />
      </div>
    </div>

    <div class="vow__caption">
      <p class="vow__title" id="vow-title"><em>{title}</em></p>
      <p class="vow__meta">{dimensions}</p>
      <p class="vow__hint">Shown to scale — sofa is approx. 200 cm wide</p>
    </div>
  </dialog>
</div>

<style>
  .vow__open {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-3);
    padding: 0.7rem 1.25rem;
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border: 1px solid var(--color-text);
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    transition: background-color var(--duration) var(--ease),
                color var(--duration) var(--ease);
  }
  .vow__open:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  /* Dialog */
  .vow__dialog {
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 0;
    border: none;
    background: #1a1816;
    color: #fff;
    overflow: hidden;
  }
  .vow__dialog::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }
  .vow__dialog[open] {
    display: flex;
    flex-direction: column;
  }

  .vow__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 10;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: rgba(0, 0, 0, 0.35);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    opacity: 0.85;
    transition: opacity var(--duration) var(--ease),
                background-color var(--duration) var(--ease);
  }
  .vow__close:hover {
    opacity: 1;
    background: rgba(0, 0, 0, 0.55);
  }

  .vow__scene {
    position: relative;
    flex: 1 1 auto;
    width: 100%;
    overflow: hidden;
  }

  .vow__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .vow__art {
    position: absolute;
    /* set by JS: left, top, width, height */
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.45),
      0 4px 10px rgba(0, 0, 0, 0.25);
    transition: opacity 200ms var(--ease);
    will-change: left, top, width, height;
  }
  .vow__art img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .vow__art:not([data-ready]) {
    opacity: 0;
  }

  .vow__caption {
    flex: 0 0 auto;
    padding: var(--space-3) var(--space-4);
    text-align: center;
    background: #0f0e0d;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .vow__title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
  }
  .vow__meta {
    margin-top: 0.25rem;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.75);
  }
  .vow__hint {
    margin-top: 0.25rem;
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
  }
</style>

<script>
  type Cleanup = () => void;

  function setupViewOnWall() {
    const roots = document.querySelectorAll<HTMLElement>('.vow');
    const cleanups: Cleanup[] = [];

    roots.forEach((root) => {
      const openBtn = root.querySelector<HTMLButtonElement>('[data-vow-open]');
      const dialog = root.querySelector<HTMLDialogElement>('[data-vow-dialog]');
      const closeBtn = root.querySelector<HTMLButtonElement>('[data-vow-close]');
      const scene = root.querySelector<HTMLElement>('[data-vow-scene]');
      const art = root.querySelector<HTMLElement>('[data-vow-art]');
      if (!openBtn || !dialog || !closeBtn || !scene || !art) return;
      if (openBtn.dataset.bound === '1') return;
      openBtn.dataset.bound = '1';

      const sceneW = Number(dialog.dataset.sceneW);
      const sceneH = Number(dialog.dataset.sceneH);
      const refPxPerCm = Number(dialog.dataset.pxPerCm);
      const hangCentreY = Number(dialog.dataset.hangY);
      const wCm = Number(dialog.dataset.wCm);
      const hCm = Number(dialog.dataset.hCm);

      function position() {
        if (!dialog!.open) return;
        const rect = scene!.getBoundingClientRect();
        // The SVG uses preserveAspectRatio="xMidYMid slice" — same logic as object-fit:cover.
        const scaleX = rect.width / sceneW;
        const scaleY = rect.height / sceneH;
        const cover = Math.max(scaleX, scaleY);

        // The displayed scene is sceneW * cover wide, sceneH * cover tall, centered.
        const displayedW = sceneW * cover;
        const displayedH = sceneH * cover;
        const offsetX = (rect.width - displayedW) / 2;
        const offsetY = (rect.height - displayedH) / 2;

        const pxPerCm = refPxPerCm * cover;
        const artWpx = wCm * pxPerCm;
        const artHpx = hCm * pxPerCm;

        // Hang centre in scene coords → screen coords
        const centreX = offsetX + (sceneW / 2) * cover;
        const centreY = offsetY + hangCentreY * cover;

        art!.style.left = `${centreX - artWpx / 2}px`;
        art!.style.top = `${centreY - artHpx / 2}px`;
        art!.style.width = `${artWpx}px`;
        art!.style.height = `${artHpx}px`;
        art!.setAttribute('data-ready', '1');
      }

      function open() {
        dialog!.showModal();
        document.body.style.overflow = 'hidden';
        // Wait one frame so dialog has its real size
        requestAnimationFrame(position);
      }
      function close() {
        if (dialog!.open) dialog!.close();
        document.body.style.overflow = '';
        art!.removeAttribute('data-ready');
      }

      const onResize = () => position();
      const onCancel = () => close();

      openBtn.addEventListener('click', open);
      closeBtn.addEventListener('click', close);
      dialog.addEventListener('cancel', onCancel); // Esc key fires 'cancel'
      // Click-outside (on backdrop): the dialog itself receives the click
      // when the user clicks the backdrop area
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) close();
      });
      window.addEventListener('resize', onResize);

      cleanups.push(() => {
        window.removeEventListener('resize', onResize);
        if (dialog!.open) dialog!.close();
        document.body.style.overflow = '';
      });
    });

    document.addEventListener('astro:before-swap', () => {
      cleanups.forEach((c) => c());
    }, { once: true });
  }

  setupViewOnWall();
  document.addEventListener('astro:page-load', setupViewOnWall);
</script>
